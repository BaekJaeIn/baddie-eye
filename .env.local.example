# Supabase — 프로젝트 대시보드 > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 배포 주소(끝에 / 없이). 카카오 OAuth redirect/QR의 기준 주소로 사용.
# 설치된 PWA·카카오톡 인앱 브라우저에서 window.location.origin이 "null"로
# 평가되는 문제를 막기 위해 반드시 설정. 예: https://baddie-eye.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Sentry (선택) — 없으면 에러 추적 비활성, 앱은 정상 동작
NEXT_PUBLIC_SENTRY_DSN=
# 아래 3개는 CI/CD 환경변수로만 관리 (소스맵 업로드용). 클라이언트 번들 포함 금지.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Web Push (Bolt 6) — `npx web-push generate-vapid-keys`로 생성
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@example.com

# Cron 리마인더 (Bolt 6) — 서버 전용. 절대 클라이언트 노출 금지.
CRON_SECRET=
# Supabase service_role 키 (Cron 전용, RLS 우회) — 절대 NEXT_PUBLIC_ 아님
SUPABASE_SERVICE_ROLE_KEY=
